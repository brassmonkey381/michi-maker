{
  "buildCommand": "EXPO_PUBLIC_CHECKOUT_OPEN=1 expo export -p web && node scripts/inject-meta.mjs",
  "outputDirectory": "dist",
  "devCommand": "expo",
  "cleanUrls": true,
  "framework": null,
  "rewrites": [
    {
      "source": "/binder/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|Twitterbot|Discordbot|Slackbot|TelegramBot|WhatsApp|LinkedInBot|Pinterest|redditbot|SkypeUriPreview|vkShare|W3C_Validator|Embedly|Iframely|Mastodon|Bluesky|OpenGraph).*"
        }
      ],
      "destination": "/api/og-binder?id=:id"
    },
    {
      "source": "/u/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|Twitterbot|Discordbot|Slackbot|TelegramBot|WhatsApp|LinkedInBot|Pinterest|redditbot|SkypeUriPreview|vkShare|W3C_Validator|Embedly|Iframely|Mastodon|Bluesky|OpenGraph).*"
        }
      ],
      "destination": "/api/og-profile?id=:id"
    },
    {
      "source": "/michi-method",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|Twitterbot|Discordbot|Slackbot|TelegramBot|WhatsApp|LinkedInBot|Pinterest|redditbot|SkypeUriPreview|vkShare|W3C_Validator|Embedly|Iframely|Mastodon|Bluesky|OpenGraph).*"
        }
      ],
      "destination": "/api/og-michi"
    },
    { "source": "/:path*", "destination": "/" }
  ]
}
