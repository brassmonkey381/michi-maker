# poke-michi environment variables
# ---------------------------------
# Copy this file to `.env` and fill in the values from your Supabase project's
# API settings: https://supabase.com/dashboard/project/_/settings/api
#
# Anything prefixed with EXPO_PUBLIC_ is inlined into the app bundle and shipped to
# every client. Only put PUBLIC keys here.

# Your project URL, e.g. https://abcdefghijklmno.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# The project's publishable key (starts with `sb_publishable_...`).
# The legacy `anon` key also works in this slot, but it is being deprecated.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Card catalog origin — the shared tcgscan-data data server (public buckets).
# With these set, the app reads catalog.json + card images from the hosted
# origin; without them it falls back to local static /browse + /card-imgs.
# catalog.json cards carry image_small (245px webp, many-card grids) and
# image_medium (640px webp, binder pages) alongside image (full size).
# -----------------------------------------------------------------------------
EXPO_PUBLIC_CATALOG_BROWSE_URL=https://bmhjizcmwtmcrstadqto.supabase.co/storage/v1/object/public/browse
EXPO_PUBLIC_CATALOG_IMG_BASE=https://bmhjizcmwtmcrstadqto.supabase.co/storage/v1/object/public

# -----------------------------------------------------------------------------
# Optional — live artwork suggestions in the binder editor (free image APIs).
# Add ONE of these (publishable, client-usable). Without a key, the editor falls
# back to the bundled public-domain art library. Pexels takes priority if both set.
# -----------------------------------------------------------------------------

# Pexels (photos) — free key: https://www.pexels.com/api/
# EXPO_PUBLIC_PEXELS_KEY=

# Pixabay (illustrations) — free key: https://pixabay.com/api/docs/
# EXPO_PUBLIC_PIXABAY_KEY=

# (The TCGdex ingestion script and its server-side vars — SUPABASE_SECRET_KEY,
# TCGDEX_LANG — were retired 2026-07-06: the shared tcgscan-data pipeline is the
# single catalogue/price/image source now, consumed via the CATALOG vars above.
# See the tcgscan-data repo for scraping and publishing.)
